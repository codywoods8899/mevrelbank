run = "cd aicg && node server.js"
modules = ["nodejs-18", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "MevrelBank Dev (verify)"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "MevrelBank Backend"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd aicg && node server.js"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "MevrelBank Dev (verify)"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd \"mevrelbank/design-systems/agents/figma/Figma Design System For Banking Ecosystem v0.1.0\" && npx vite --port 5173 --host 0.0.0.0"
waitForPort = 5173

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "MevrelBank Backend"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd mevrelbank/backend && node server.js"
waitForPort = 3001

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5050
externalPort = 3000

[[ports]]
localPort = 5173
externalPort = 5173

[[ports]]
localPort = 5174
externalPort = 3002

[deployment]
deploymentTarget = "vm"
run = ["node", "aicg/server.js"]
build = ["npm", "--prefix", "aicg", "install", "--production"]

